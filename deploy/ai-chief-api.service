[Unit]
Description=AI Chief Agent - FastAPI Backend
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/ai-chief-agent
ExecStart=/opt/ai-chief-agent/.venv/bin/uvicorn app.api.server:app \
    --host 0.0.0.0 \
    --port 8000
Restart=always
RestartSec=5
Environment="PATH=/opt/ai-chief-agent/.venv/bin:/usr/bin:/bin"

[Install]
WantedBy=multi-user.target
